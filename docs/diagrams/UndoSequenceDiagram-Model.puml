@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Model MODEL_COLOR_T1
participant ":Model" as Model MODEL_COLOR
participant ":VersionedHrmanager" as VersionedHrmanager MODEL_COLOR
end box

[-> Model : undoHrmanager()
activate Model

Model -> VersionedHrmanager : undo()
activate VersionedHrmanager

VersionedHrmanager -> VersionedHrmanager :resetData(ReadOnlyHrmanager)
VersionedHrmanager --> Model :
deactivate VersionedHrmanager

[<-- Model
deactivate Model

@enduml
